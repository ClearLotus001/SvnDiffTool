{
  "name": "svn-diff-tool",
  "version": "1.0.0",
  "description": "SvnDiffTool — TortoiseSVN external diff viewer for text and workbook files",
  "main": "dist-electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ClearLotus001/SvnDiffTool.git"
  },
  "scripts": {
    "dev": "tsx scripts/dev-app.ts",
    "dev:app": "tsx scripts/dev-app.ts",
    "dev:electron:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:run": "tsx scripts/dev-electron-runner.ts",
    "build": "npm run typecheck && npm run build:renderer && npm run build:electron && npm run build:rust",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:rust": "tsx scripts/build-rust.ts",
    "build:win": "npm run build && electron-builder --win nsis",
    "build:win:release": "npm run build && electron-builder --win nsis",
    "typecheck": "npm run typecheck:renderer && npm run typecheck:electron && npm run typecheck:scripts",
    "typecheck:renderer": "tsc --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "test:workbook": "tsx --test tests/*.test.ts",
    "verify:single-instance-cache": "tsx scripts/verify-single-instance-cache.ts",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.svnexceldifftool.app",
    "productName": "SvnDiffTool",
    "artifactName": "${productName}-${version}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "executableName": "SvnDiffTool"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ClearLotus001",
        "repo": "SvnDiffTool",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "rust/target/release/svn_excel_parser.exe",
        "to": "bin/svn_excel_parser.exe"
      }
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "fast-xml-parser": "^5.5.6",
    "fflate": "^0.8.2"
  }
}
